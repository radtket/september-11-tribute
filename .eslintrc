{
  "root": true,
  "extends": ["airbnb-base", "prettier"],
  "plugins": ["prettier", "jquery"],
  "rules": {
		"comma-dangle": 0,
		"prettier/prettier": [
			"error",
			{
				"trailingComma": "es5",
				"printWidth": 80,
				"jsxBracketSameLine": false,
				"number-leading-zero": null,
        "singleQuote": false
			}
		]
  },
  "env": {
    "browser": true,
    "es6": true,
    "node": true,
    "commonjs": true,
    "jquery": true
  }
}
